# ============================================
# Dispatchr Logistics — Environment Variables
# ============================================

# --- Database ---
POSTGRES_USER=dispatchr
POSTGRES_PASSWORD=dispatchr_secret
POSTGRES_DB=dispatchr_logistics
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://dispatchr:dispatchr_secret@localhost:5432/dispatchr_logistics

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- JWT Auth ---
JWT_ACCESS_SECRET=your-access-secret-change-me
JWT_REFRESH_SECRET=your-refresh-secret-change-me
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- Admin ---
ADMIN_IDS=123456789,987654321

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your-bot-token
TARGET_GROUP_ID=-1003131208840
REPORT_GROUP_ID=-1003303026585

# --- GramJS Sessions (1-5) ---
TELEGRAM_API_ID=your-api-id
TELEGRAM_API_HASH=your-api-hash
TELEGRAM_SESSION_STRING=
TELEGRAM_SESSION_STRING_2=
TELEGRAM_SESSION_STRING_3=
TELEGRAM_SESSION_STRING_4=
TELEGRAM_SESSION_STRING_5=

# --- Click.uz ---
CLICK_SERVICE_ID=your-click-service-id
CLICK_MERCHANT_ID=your-click-merchant-id
CLICK_SECRET_KEY=your-click-secret

# --- Payme ---
PAYME_MERCHANT_ID=your-payme-merchant-id
PAYME_MERCHANT_KEY=your-payme-merchant-key

# --- SemySMS ---
SEMYSMS_TOKEN=your-semysms-token
SEMYSMS_DEVICE=your-device-id

# --- Sentry ---
SENTRY_DSN=

# --- App ---
NODE_ENV=development
PORT=3000
